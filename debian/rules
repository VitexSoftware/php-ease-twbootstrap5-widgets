#!/usr/bin/make -f

PKG_PATH:=/usr/share/php/Ease
BUILD_DIR:=build

%:
	dh $@

override_dh_auto_test:
	echo tests temporarly skipped for now in rules file

override_dh_clean:
	rm -rf tmp
	dh_clean

override_dh_install:
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  debian/composer.json |sponge debian/composer.json
	npm install --prefix tmp bootstrap5-toggle
	dh_install
	sed -e "/includeCss/c\        \$$this->includeCss(\'\/javascript\/bootstrap5\/css\/bootstrap5-toggle.min.css\');" -i debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/Toggle.php 
	sed -e "/includeJavascript/c\        \$$this->includeJavascript(\'\/javascript\/bootstrap5\/js\/bootstrap5-toggle.jquery.min.js\');"   -i debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/Toggle.php 
	phpab --output debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/autoload.php --basedir debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/ --tolerant debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/
	echo 'require_once("/usr/share/php/EaseTWB5/autoload.php");' >> debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/php/EaseTWB5Widgets/autoload.php
	install -m0755 -d debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/pkg-php-tools/autoloaders
	echo 'deb ease-core EaseTWB5Widgets/autoload.php' > debian/php-vitexsoftware-ease-bootstrap5-widgets/usr/share/pkg-php-tools/autoloaders/php-vitexsoftware-ease-bootstrap5-widgets

